<Window x:Class="BankerDeskOps.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BankerDeskOps.Wpf"
        xmlns:views="clr-namespace:BankerDeskOps.Wpf.Views"
        xmlns:viewmodels="clr-namespace:BankerDeskOps.Wpf.ViewModels"
        mc:Ignorable="d"
        Title="BankerDeskOps - Banking Operations" Height="600" Width="1000">
    <Window.Resources>
        <!-- DataTemplate for LoansViewModel -->
        <DataTemplate DataType="{x:Type viewmodels:LoansViewModel}">
            <views:LoansView/>
        </DataTemplate>
        
        <!-- DataTemplate for RetailAccountsViewModel -->
        <DataTemplate DataType="{x:Type viewmodels:RetailAccountsViewModel}">
            <views:RetailAccountsView/>
        </DataTemplate>

        <!-- DataTemplate for BankClientsViewModel -->
        <DataTemplate DataType="{x:Type viewmodels:BankClientsViewModel}">
            <views:BankClientsView/>
        </DataTemplate>

        <!-- DataTemplate for UsersViewModel -->
        <DataTemplate DataType="{x:Type viewmodels:UsersViewModel}">
            <views:UsersView/>
        </DataTemplate>

        <!-- DataTemplate for TransactionsViewModel -->
        <DataTemplate DataType="{x:Type viewmodels:TransactionsViewModel}">
            <views:TransactionsView/>
        </DataTemplate>

        <!-- DataTemplate for CurrencyViewModel -->
        <DataTemplate DataType="{x:Type viewmodels:CurrencyViewModel}">
            <views:CurrencyView/>
        </DataTemplate>

        <!-- DataTemplate for ProductViewModel -->
        <DataTemplate DataType="{x:Type viewmodels:ProductViewModel}">
            <views:ProductView/>
        </DataTemplate>

        <!-- DataTemplate for RateViewModel -->
        <DataTemplate DataType="{x:Type viewmodels:RateViewModel}">
            <views:RateView/>
        </DataTemplate>

        <!-- DataTemplate for FeeViewModel -->
        <DataTemplate DataType="{x:Type viewmodels:FeeViewModel}">
            <views:FeeView/>
        </DataTemplate>

        <!-- DataTemplate for CommissionViewModel -->
        <DataTemplate DataType="{x:Type viewmodels:CommissionViewModel}">
            <views:CommissionView/>
        </DataTemplate>

        <!-- DataTemplate for LoanApplicationReviewViewModel -->
        <DataTemplate DataType="{x:Type viewmodels:LoanApplicationReviewViewModel}">
            <views:LoanApplicationReviewView/>
        </DataTemplate>
    </Window.Resources>
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Navigation Sidebar -->
        <StackPanel Grid.Column="0" Background="#f0f0f0" Margin="10">
            <TextBlock Text="Navigation" FontSize="16" FontWeight="Bold" Margin="0,0,0,20"/>
            <Button Content="Loans" Height="40" Margin="0,5" Command="{Binding NavigateToLoansCommand}" Background="#007acc" Foreground="White"/>
            <Button Content="Retail Accounts" Height="40" Margin="0,5" Command="{Binding NavigateToRetailAccountsCommand}" Background="#007acc" Foreground="White"/>
            <Button Content="Bank Clients" Height="40" Margin="0,5" Command="{Binding NavigateToBankClientsCommand}" Background="#007acc" Foreground="White"/>
            <Button Content="Users" Height="40" Margin="0,5" Command="{Binding NavigateToUsersCommand}" Background="#6f42c1" Foreground="White"/>
            <Button Content="Transactions" Height="40" Margin="0,5" Command="{Binding NavigateToTransactionsCommand}" Background="#007acc" Foreground="White"/>

            <TextBlock Text="Configuration" FontSize="14" FontWeight="Bold" Margin="0,20,0,10" Foreground="#6c757d"/>
            <Button Content="Currencies" Height="40" Margin="0,5" Command="{Binding NavigateToCurrenciesCommand}" Background="#e83e8c" Foreground="White"/>
            <Button Content="Products" Height="40" Margin="0,5" Command="{Binding NavigateToProductsCommand}" Background="#e83e8c" Foreground="White"/>
            <Button Content="Rates" Height="40" Margin="0,5" Command="{Binding NavigateToRatesCommand}" Background="#e83e8c" Foreground="White"/>
            <Button Content="Fees" Height="40" Margin="0,5" Command="{Binding NavigateToFeesCommand}" Background="#e83e8c" Foreground="White"/>
            <Button Content="Commissions" Height="40" Margin="0,5" Command="{Binding NavigateToCommissionsCommand}" Background="#e83e8c" Foreground="White"/>

            <TextBlock Text="Review" FontSize="14" FontWeight="Bold" Margin="0,20,0,10" Foreground="#6c757d"/>
            <Button Content="Loan Applications" Height="40" Margin="0,5" Command="{Binding NavigateToLoanApplicationReviewCommand}" Background="#fd7e14" Foreground="White"/>
        </StackPanel>

        <!-- Content Area -->
        <ContentControl Grid.Column="1" Content="{Binding CurrentView}"/>
    </Grid>
</Window>
