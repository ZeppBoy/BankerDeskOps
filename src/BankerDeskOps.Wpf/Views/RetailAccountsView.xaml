<UserControl x:Class="BankerDeskOps.Wpf.Views.RetailAccountsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:BankerDeskOps.Wpf.Views"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="Retail Accounts Management" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>

        <!-- Open Account Form -->
        <Grid Grid.Row="1" Background="#f9f9f9" Margin="10,10,10,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Label Grid.Column="0" Content="Customer Name:" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Text="{Binding CustomerName}" Margin="0,0,10,0" Padding="5"/>

            <Label Grid.Column="2" Content="Account Type:" VerticalAlignment="Center"/>
            <ComboBox Grid.Column="3" SelectedItem="{Binding AccountType}" Margin="0,0,10,0" Padding="5">
                <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">Checking</System:String>
                <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">Savings</System:String>
            </ComboBox>

            <Label Grid.Column="4" Content="Initial Deposit:" VerticalAlignment="Center"/>
            <TextBox Grid.Column="5" Text="{Binding InitialDeposit}" Padding="5"/>
        </Grid>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10" VerticalAlignment="Top">
            <Button Content="Open Account" Command="{Binding OpenAccountCommand}" Height="35" Padding="15,5" Background="#28a745" Foreground="White" Margin="0,0,5,0"/>
            <Button Content="Deposit" Command="{Binding DepositCommand}" Height="35" Padding="15,5" Background="#17a2b8" Foreground="White" Margin="0,0,5,0"/>
            <Button Content="Withdraw" Command="{Binding WithdrawCommand}" Height="35" Padding="15,5" Background="#ffc107" Foreground="Black" Margin="0,0,5,0"/>
            <Button Content="Close Account" Command="{Binding CloseAccountCommand}" Height="35" Padding="15,5" Background="#dc3545" Foreground="White" Margin="0,0,5,0"/>
            <Button Content="Refresh" Command="{Binding LoadAccountsCommand}" Height="35" Padding="15,5" Background="#007acc" Foreground="White" Margin="0,0,5,0"/>
            
            <Label Content="Transaction Amount:" VerticalAlignment="Center" Margin="20,0,0,0"/>
            <TextBox Width="100" Text="{Binding TransactionAmount}" Padding="5"/>
        </StackPanel>

        <!-- Accounts DataGrid -->
        <DataGrid Grid.Row="2" ItemsSource="{Binding Accounts}" SelectedItem="{Binding SelectedAccount}" CanUserAddRows="False" AutoGenerateColumns="False" Margin="0,40,0,0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="200"/>
                <DataGridTextColumn Header="Customer Name" Binding="{Binding CustomerName}" Width="*"/>
                <DataGridTextColumn Header="Account Number" Binding="{Binding AccountNumber}" Width="150"/>
                <DataGridTextColumn Header="Balance" Binding="{Binding Balance, StringFormat=C}" Width="120"/>
                <DataGridTextColumn Header="Account Type" Binding="{Binding AccountType}" Width="100"/>
                <DataGridTextColumn Header="Opened" Binding="{Binding OpenedAt, StringFormat=d}" Width="100"/>
                <DataGridTextColumn Header="IBAN" Binding="{Binding Iban}" Width="150"/> <!-- Added IBAN column -->
            </DataGrid.Columns>
        </DataGrid>

        <!-- Error Message -->
        <TextBlock Grid.Row="3" Text="{Binding ErrorMessage}" Foreground="#dc3545" Margin="0,10,0,0" TextWrapping="Wrap"/>
    </Grid>
</UserControl>
