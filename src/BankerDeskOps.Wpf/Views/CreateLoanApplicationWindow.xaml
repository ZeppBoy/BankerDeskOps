<Window x:Class="BankerDeskOps.Wpf.Views.CreateLoanApplicationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Loan Application" Height="350" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Product -->
            <RowDefinition Height="Auto"/>
            <!-- Amount -->
            <RowDefinition Height="Auto"/>
            <!-- Term -->
            <RowDefinition Height="Auto"/>
            <!-- Error message -->
            <RowDefinition Height="Auto"/>
            <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="New Loan Application" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

        <!-- Product Selection -->
        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <Label Content="Product:"/>
            <ComboBox x:Name="cmbProduct" ItemsSource="{Binding Products}" SelectedItem="{Binding SelectedProduct}"
                      DisplayMemberPath="Name" Padding="5"/>
        </StackPanel>

        <!-- Amount -->
        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <Label Content="Amount:"/>
            <TextBox x:Name="txtAmount" Text="{Binding Amount, UpdateSourceTrigger=PropertyChanged}" Padding="5"/>
        </StackPanel>

        <!-- Term -->
        <StackPanel Grid.Row="3" Margin="0,0,0,12">
            <Label Content="Term (Months):"/>
            <TextBox x:Name="txtTerm" Text="{Binding TermMonths, UpdateSourceTrigger=PropertyChanged}" Padding="5"/>
        </StackPanel>

        <!-- Error Message -->
        <TextBlock Grid.Row="4" Text="{Binding ErrorMessage}" Foreground="#dc3545" Margin="0,0,0,12" TextWrapping="Wrap"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Create" Command="{Binding CreateCommand}" Height="35" Padding="25,5"
                    Background="#28a745" Foreground="White" Margin="0,0,10,0" IsDefault="True"/>
            <Button Content="Cancel" Command="{Binding CancelCommand}" Height="35" Padding="25,5"
                    Background="#6c757d" Foreground="White" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
