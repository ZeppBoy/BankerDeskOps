<UserControl x:Class="BankerDeskOps.Wpf.Views.LoanApplicationReviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="750" d:DesignWidth="900">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Filter & Comment -->
                <RowDefinition Height="Auto"/>
                <!-- Action Buttons -->
                <RowDefinition Height="Auto"/>
                <!-- Applications Grid + Documents -->
                <RowDefinition Height="*"/>
                <!-- Repayment Schedule Section -->
                <RowDefinition Height="Auto"/>
                <!-- Error Message -->
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <TextBlock Grid.Row="0" Text="Loan Application Review" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>

            <!-- Filter & Comment Section -->
            <Border Grid.Row="1" Background="#f9f9f9" Padding="10">
                <StackPanel>
                    <Grid Margin="0,0,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Label Grid.Column="0" Content="Filter by Status:" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Text="{Binding FilterStatus}" Padding="5"/>
                    </Grid>

                    <Grid Margin="0,0,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Label Grid.Column="0" Content="Comment:" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Text="{Binding StatusComment}" Padding="5"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Action Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,10">
                <Button Content="Create Loan Application" Command="{Binding OpenCreateDialogCommand}" Height="35" Padding="15,5" Background="#007bff" Foreground="White" Margin="0,0,5,0"/>
                <Button Content="Approve" Command="{Binding ApproveApplicationCommand}" Height="35" Padding="15,5" Background="#28a745" Foreground="White" Margin="0,0,5,0"/>
                <Button Content="Reject" Command="{Binding RejectApplicationCommand}" Height="35" Padding="15,5" Background="#dc3545" Foreground="White" Margin="0,0,5,0"/>
                <Button Content="Delete" Command="{Binding DeleteApplicationCommand}" Height="35" Padding="15,5" Background="#6c757d" Foreground="White" Margin="0,0,5,0"/>
                <Button Content="Upload Document" Command="{Binding UploadDocumentCommand}" Height="35" Padding="15,5" Background="#ffc107" Foreground="Black" Margin="0,0,5,0"/>
                <Button Content="Remove Doc" Command="{Binding RemoveDocumentCommand}" Height="35" Padding="15,5" Background="#fd7e14" Foreground="White" Margin="0,0,5,0"/>
                <Button Content="Refresh" Command="{Binding LoadApplicationsCommand}" Height="35" Padding="15,5" Background="#17a2b8" Foreground="White"/>
            </StackPanel>

            <!-- Applications Grid + Documents -->
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <DataGrid Grid.Column="0" ItemsSource="{Binding Applications}" SelectedItem="{Binding SelectedApplication}" CanUserAddRows="False" AutoGenerateColumns="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="120"/>
                        <DataGridTextColumn Header="Request ID" Binding="{Binding RequestId}" Width="120"/>
                        <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat=C}" Width="120"/>
                        <DataGridTextColumn Header="Term (Months)" Binding="{Binding TermMonths}" Width="100"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                        <DataGridTextColumn Header="Created" Binding="{Binding CreatedAt, StringFormat='dd.MM.yyyy'}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>

                <ListBox Grid.Column="1" ItemsSource="{Binding UploadedDocumentNames}" Margin="5,0,0,0" Background="#f9f9f9" BorderBrush="#dee2e6"/>
            </Grid>

            <!-- Repayment Schedule Section -->
            <Border Grid.Row="4" Margin="0,15,0,0">
                <DockPanel>
                    <!-- Header -->
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Repayment Schedule" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Button Content="Load Schedules" Command="{Binding LoadSchedulesCommand}" Height="30" Padding="12,3"
                                Background="#007bff" Foreground="White" Margin="15,0,5,0"/>
                    </StackPanel>

                    <!-- New Entry Form -->
                    <Border DockPanel.Dock="Top" Background="#e8f4fd" Padding="8" Margin="0,0,0,8" BorderBrush="#b3d9ff" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Label Grid.Column="0" Content="#:" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding NewPaymentNumber, UpdateSourceTrigger=PropertyChanged}" Padding="4" MaxWidth="60"/>

                            <Label Grid.Column="2" Content="Due Date:" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            <DatePicker Grid.Column="3" SelectedDate="{Binding NewDueDate, UpdateSourceTrigger=PropertyChanged}" Padding="4" MaxWidth="120"/>

                            <Label Grid.Column="4" Content="Principal:" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            <TextBox Grid.Column="5" Text="{Binding NewPrincipalAmount, UpdateSourceTrigger=PropertyChanged}" Padding="4" MaxWidth="100"/>

                            <Label Grid.Column="6" Content="Interest:" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            <TextBox Grid.Column="7" Text="{Binding NewInterestAmount, UpdateSourceTrigger=PropertyChanged}" Padding="4" MaxWidth="100"/>

                            <Label Grid.Column="8" Content="Total:" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            <TextBox Grid.Column="9" Text="{Binding NewTotalPayment, UpdateSourceTrigger=PropertyChanged}" Padding="4" MaxWidth="100"/>

                            <Button Grid.Column="10" Content="Add Entry" Command="{Binding AddScheduleEntryCommand}"
                                    Height="30" Padding="12,3" Background="#28a745" Foreground="White" Margin="8,0,0,0"/>
                        </Grid>
                    </Border>

                    <!-- Schedule DataGrid -->
                    <DataGrid ItemsSource="{Binding RepaymentSchedules}" SelectedItem="{Binding SelectedSchedule}"
                              CanUserAddRows="False" AutoGenerateColumns="False" IsReadOnly="True"
                              SelectionMode="Single" SelectionUnit="FullRow">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Binding="{Binding PaymentNumber}" Width="50"/>
                            <DataGridTextColumn Header="Due Date" Binding="{Binding DueDate, StringFormat='dd.MM.yyyy'}" Width="100"/>
                            <DataGridTextColumn Header="Principal" Binding="{Binding PrincipalAmount, StringFormat='{}{0:C2}'}" Width="100"/>
                            <DataGridTextColumn Header="Interest" Binding="{Binding InterestAmount, StringFormat='{}{0:C2}'}" Width="100"/>
                            <DataGridTextColumn Header="Total Payment" Binding="{Binding TotalPayment, StringFormat='{}{0:C2}'}" Width="110"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Schedule Action Buttons -->
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="Delete Selected Entry" Command="{Binding DeleteScheduleEntryCommand}"
                                Height="30" Padding="12,3" Background="#dc3545" Foreground="White"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Error Message -->
            <TextBlock Grid.Row="5" Text="{Binding ErrorMessage}" Foreground="#dc3545" Margin="0,10,0,0" TextWrapping="Wrap"/>
        </Grid>
    </ScrollViewer>
</UserControl>
