<Window x:Class="BankerDeskOps.Wpf.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BankerDeskOps - Login" Height="350" Width="400"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:InvertBoolConverter x:Key="InvertBoolConverter"
                                 xmlns:local="clr-namespace:BankerDeskOps.Wpf.Converters"/>
    </Window.Resources>
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="BankerDeskOps" FontSize="24" FontWeight="Bold"
                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <!-- Username -->
        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <Label Content="Username:" FontWeight="SemiBold"/>
            <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                     IsEnabled="{Binding IsAnonymous, Converter={StaticResource InvertBoolConverter}}"
                     Padding="5" FontSize="14"/>
        </StackPanel>

        <!-- Password -->
        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <Label Content="Password:" FontWeight="SemiBold"/>
            <PasswordBox x:Name="PasswordBox"
                         IsEnabled="{Binding IsAnonymous, Converter={StaticResource InvertBoolConverter}}"
                         Padding="5" FontSize="14"
                         PasswordChanged="PasswordBox_PasswordChanged"/>
        </StackPanel>

        <!-- Anonymous checkbox -->
        <CheckBox Grid.Row="3" Content="Anonymous Access"
                  IsChecked="{Binding IsAnonymous}" Margin="0,0,0,15" FontSize="13"/>

        <!-- Login Button -->
        <Button Grid.Row="4" Command="{Binding LoginCommand}" Height="40"
                Background="#007acc" Foreground="White" FontSize="14" FontWeight="SemiBold"
                Margin="0,0,0,10"
                IsEnabled="{Binding IsLoading, Converter={StaticResource InvertBoolConverter}}">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Content" Value="Log In"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsAnonymous}" Value="True">
                            <Setter Property="Content" Value="Enter as Guest"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsLoading}" Value="True">
                            <Setter Property="Content" Value="Logging in..."/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>

        <!-- Error message -->
        <TextBlock Grid.Row="5" Text="{Binding ErrorMessage, Mode=OneWay}" Foreground="#dc3545"
                    Visibility="{Binding IsErrorMessageVisible, Converter={StaticResource BoolToVis}}"
                    TextWrapping="Wrap" FontSize="12"/>
    </Grid>

  
</Window>
