<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:BankerDeskOps.Avalonia.Views"
        xmlns:viewmodels="clr-namespace:BankerDeskOps.Avalonia.ViewModels"
        x:Class="BankerDeskOps.Avalonia.Views.MainWindow"
        Title="BankerDeskOps - Banking Operations"
        Height="650" Width="1100"
        MinHeight="500" MinWidth="800">

    <!-- DataTemplates tell ContentControl which UserControl to render for each ViewModel type -->
    <Window.DataTemplates>
        <DataTemplate DataType="{x:Type viewmodels:LoansViewModel}">
            <views:LoansView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:RetailAccountsViewModel}">
            <views:RetailAccountsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:BankClientsViewModel}">
            <views:BankClientsView/>
        </DataTemplate>
    </Window.DataTemplates>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Navigation Sidebar -->
        <Border Grid.Column="0" Background="#f0f0f0">
            <StackPanel Margin="10">
                <TextBlock Text="Navigation" FontSize="16" FontWeight="Bold" Margin="0,10,0,20"/>
                <Button Content="Loans"
                        Height="40" Margin="0,5"
                        Command="{Binding NavigateToLoansCommand}"
                        Background="#007acc" Foreground="White"
                        HorizontalAlignment="Stretch"/>
                <Button Content="Retail Accounts"
                        Height="40" Margin="0,5"
                        Command="{Binding NavigateToRetailAccountsCommand}"
                        Background="#007acc" Foreground="White"
                        HorizontalAlignment="Stretch"/>
                <Button Content="Bank Clients"
                        Height="40" Margin="0,5"
                        Command="{Binding NavigateToBankClientsCommand}"
                        Background="#007acc" Foreground="White"
                        HorizontalAlignment="Stretch"/>
            </StackPanel>
        </Border>

        <!-- Content Area — displays the active ViewModel via DataTemplate above -->
        <ContentControl Grid.Column="1" Content="{Binding CurrentView}"/>
    </Grid>
</Window>
