<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="BankerDeskOps.Avalonia.Views.RetailAccountsView">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="Retail Accounts Management" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>

        <!-- Open Account Form -->
        <Border Grid.Row="1" Background="#f9f9f9" BorderBrush="#dee2e6" BorderThickness="1" Padding="10" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Customer Name:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox   Grid.Column="1" Text="{Binding CustomerName}" Margin="0,0,10,0" Padding="5"/>

                <TextBlock Grid.Column="2" Text="Account Type:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <!-- ComboBox items are strings; SelectedItem binds to AccountType enum via ToString() display -->
                <ComboBox  Grid.Column="3" SelectedItem="{Binding AccountType}" Margin="0,0,10,0" Padding="5">
                    <x:String>Checking</x:String>
                    <x:String>Savings</x:String>
                </ComboBox>

                <TextBlock Grid.Column="4" Text="Initial Deposit:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox   Grid.Column="5" Text="{Binding InitialDeposit}" Padding="5"/>
            </Grid>
        </Border>

        <!-- Action Buttons + Transaction Amount field -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="Open Account"  Command="{Binding OpenAccountCommand}"
                    Height="35" Padding="15,5" Background="#28a745" Foreground="White" Margin="0,0,5,0"/>
            <Button Content="Deposit"       Command="{Binding DepositCommand}"
                    Height="35" Padding="15,5" Background="#17a2b8" Foreground="White" Margin="0,0,5,0"/>
            <Button Content="Withdraw"      Command="{Binding WithdrawCommand}"
                    Height="35" Padding="15,5" Background="#ffc107" Foreground="Black" Margin="0,0,5,0"/>
            <Button Content="Close Account" Command="{Binding CloseAccountCommand}"
                    Height="35" Padding="15,5" Background="#dc3545" Foreground="White" Margin="0,0,5,0"/>
            <Button Content="Refresh"       Command="{Binding LoadAccountsCommand}"
                    Height="35" Padding="15,5" Background="#007acc" Foreground="White" Margin="0,0,20,0"/>

            <TextBlock Text="Transaction Amount:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox   Width="110" Text="{Binding TransactionAmount}" Padding="5" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Accounts DataGrid -->
        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding Accounts}"
                  SelectedItem="{Binding SelectedAccount}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"             Binding="{Binding Id}"                            Width="220"/>
                <DataGridTextColumn Header="Customer Name"  Binding="{Binding CustomerName}"                  Width="*"/>
                <DataGridTextColumn Header="Account Number" Binding="{Binding AccountNumber}"                 Width="150"/>
                <DataGridTextColumn Header="Balance"        Binding="{Binding Balance, StringFormat={}{0:C}}" Width="120"/>
                <DataGridTextColumn Header="Account Type"   Binding="{Binding AccountType}"                   Width="110"/>
                <DataGridTextColumn Header="Opened"         Binding="{Binding OpenedAt, StringFormat={}{0:d}}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Status / Error Message -->
        <TextBlock Grid.Row="4"
                   Text="{Binding ErrorMessage}"
                   Foreground="#dc3545"
                   Margin="0,8,0,0"
                   TextWrapping="Wrap"/>
    </Grid>
</UserControl>
